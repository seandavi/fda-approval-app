# openFDA API key — optional. Get one at https://open.fda.gov/apis/authentication/
# Without a key, requests are limited to 240/min per IP.
VITE_OPENFDA_API_KEY=

# Google Analytics 4 Measurement ID, e.g. G-XXXXXXXXXX. Leave blank to disable GA.
VITE_GA_MEASUREMENT_ID=

# Maximum number of names accepted in a single batch lookup. Larger batches
# multiply API calls (each name hits up to ~12 endpoints) and can stress
# upstream rate limits. Bulk file upload for larger inputs is a v2 feature.
VITE_BATCH_LIMIT=100
